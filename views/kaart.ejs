<%- include('partials/head', { title: 'Mannenvakanties — kaart' }) %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
<%- include('partials/pubnav', { active: 'kaart' }) %>

<header class="cover cover-slim page-hero">
  <% if (typeof pageHeroId !== 'undefined' && pageHeroId) { %><div class="hero-bg" style="background-image:url('/hero/<%= pageHeroId %>')" aria-hidden="true"></div><% } %>
  <div class="cover-frame">
    <h1>Op de kaart</h1>
    <p class="tagline">Waar de mannen neerstreken. Klik een plek aan voor dat jaar.</p>
    <%- include('partials/entries', { active: 'kaart' }) %>
  </div>
</header>

<main class="map-wrap">
  <% if (years.length) { %>
    <div id="map"></div>
    <script id="map-data" type="application/json"><%- JSON.stringify(years.map(function(y){ return { id: y.id, year: y.year, place: y.place, lat: y.lat, lng: y.lng, cover_id: y.cover_id, count: y.photo_count }; })).replace(/</g, '\\u003c') %></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script src="/kaart.js"></script>
  <% } else { %>
    <p class="empty-note">Nog geen plaatsen met coördinaten. Voeg ze toe via <a href="/beheer">Beheer</a> → een jaar openen → coördinaten invullen.</p>
  <% } %>
</main>

<footer class="colophon">
  <p class="mark">M&middot;V</p>
  <p>Mannenvakanties — het album</p>
</footer>

<%- include('partials/foot') %>
