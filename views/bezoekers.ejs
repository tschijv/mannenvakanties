<%- include('partials/head', { title: 'Anonieme bezoekers — Beheer' }) %>
<%- include('partials/topbar') %>

<main class="beheer">
  <p class="beheer-foot"><a href="/beheer/statistieken">&larr; Statistieken</a> &middot; <a href="/beheer/herkomst">Herkomst op de kaart</a></p>
  <header class="beheer-head">
    <h1>Anonieme bezoekers</h1>
    <p>Niet-ingelogde bezoekers, geteld per apparaat (anonieme cookie). <strong><%= totals.humans %></strong> mensen en <strong><%= totals.bots %></strong> bots/crawlers; <%= totals.geo %> met een herkenbare herkomst.</p>
    <p class="filter-tabs">
      <a class="<%= filter === 'alle' ? 'is-active' : '' %>" href="/beheer/bezoekers">Alles</a>
      <a class="<%= filter === 'mens' ? 'is-active' : '' %>" href="/beheer/bezoekers?type=mens">Alleen mensen</a>
      <a class="<%= filter === 'bot' ? 'is-active' : '' %>" href="/beheer/bezoekers?type=bot">Alleen bots</a>
    </p>
  </header>

  <% if (topBots && topBots.length) { %>
    <section class="card">
      <h2>Bots / crawlers</h2>
      <table class="leden-table">
        <thead><tr><th>Crawler</th><th>Weergaves</th><th>Keren langs</th></tr></thead>
        <tbody>
          <% topBots.forEach(function(b){ %>
            <tr><td><%= b.bot_name %></td><td><%= b.views %></td><td><%= b.visitors %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  <% } %>

  <section class="card">
    <% if (visitors.length) { %>
      <table class="leden-table">
        <thead><tr><th>Soort</th><th>Herkomst</th><th>Weergaves</th><th>Eerste bezoek</th><th>Laatste bezoek</th></tr></thead>
        <tbody>
          <% visitors.forEach(function(v){ %>
            <tr>
              <td><% if (v.is_bot) { %><span class="badge-bot">🤖 <%= v.bot_name || 'bot' %></span><% } else { %><span class="badge-human">👤 mens</span><% } %></td>
              <td><%= v.herkomst || '—' %></td>
              <td><%= v.views %></td>
              <td class="muted log-time" data-utc="<%= v.first_seen %>"><%= v.first_seen %></td>
              <td class="muted log-time" data-utc="<%= v.last_seen %>"><%= v.last_seen %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <% if (visitors.length >= 500) { %><p class="muted small">De 500 meest recente bezoekers worden getoond.</p><% } %>
    <% } else { %>
      <p class="muted">Geen bezoekers in deze selectie.</p>
    <% } %>
  </section>
</main>

<script>
  document.querySelectorAll('.log-time').forEach(function (el) {
    var raw = el.getAttribute('data-utc'); if (!raw) return;
    var d = new Date(raw.replace(' ', 'T') + 'Z');
    if (!isNaN(d)) el.textContent = d.toLocaleString('nl-NL', { dateStyle: 'medium', timeStyle: 'short' });
  });
</script>
<%- include('partials/foot') %>
