<%- include('partials/head', { title: 'Namen — Mannenvakanties' }) %>
<%- include('partials/pubnav', { active: 'namen' }) %>

<header class="cover cover-slim">
  <div class="cover-frame">
    <h1>Wie is wie</h1>
    <p class="tagline">De mannen door de jaren heen — klik een gezicht voor alle foto's.</p>
  </div>
</header>

<main class="names-wrap">
  <div class="names-toolbar">
    <span class="names-count"><%= persons.length %> <%= persons.length === 1 ? 'persoon' : 'personen' %></span>
    <% if (typeof untagged !== 'undefined' && untagged) { %>
      <a class="btn" href="/beheer/gezichten/benoem"><%= untagged %> gezicht<%= untagged === 1 ? '' : 'en' %> nog te benoemen &rarr;</a>
    <% } %>
    <form method="post" action="/beheer/persoon" class="names-add">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <input type="text" name="name" placeholder="Naam van een nieuwe persoon" autocomplete="off" aria-label="Naam nieuwe persoon">
      <button class="btn ghost" type="submit">+ Persoon toevoegen</button>
    </form>
  </div>
  <% if (persons.length) { %>
    <ul class="face-grid">
      <% persons.forEach(function(pe){ %>
        <li>
          <a class="face-card<%= pe.name ? '' : ' is-unnamed' %>" href="/persoon/<%= pe.id %>">
            <span class="face-thumb">
              <% if (pe.cover) { %>
                <%- include('partials/facecrop', { face: pe.cover }) %>
              <% } else { %>
                <span class="face-empty" aria-hidden="true">?</span>
              <% } %>
            </span>
            <span class="face-name"><%= pe.name || ('Naamloos #' + pe.seq) %></span>
            <span class="face-count"><%= pe.face_count %> foto<%= pe.face_count === 1 ? '' : "'s" %></span>
          </a>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p class="empty-note">Nog geen gezichten getagd. Open een foto in een jaar en kies <b>“Tag gezichten”</b> om te beginnen.</p>
  <% } %>
</main>

<footer class="colophon">
  <p class="mark">M&middot;V</p>
  <p>Mannenvakanties — het album</p>
</footer>
<%- include('partials/foot') %>
