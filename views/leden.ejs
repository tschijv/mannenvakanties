<%- include('partials/head', { title: 'Leden — Beheer' }) %>
<%- include('partials/topbar') %>

<main class="beheer">
  <p class="beheer-foot"><a href="/beheer">&larr; Terug naar beheer</a></p>
  <header class="beheer-head">
    <h1>Leden &amp; beheerders</h1>
    <p>Beheerders kunnen verwijderde foto's herstellen en jaren verwijderen. Maak hier iemand beheerder &mdash; bijvoorbeeld Anton, zodra hij zich heeft aangemeld.</p>
  </header>

  <section class="card">
    <table class="leden-table">
      <thead><tr><th>Lid</th><th>Rol</th><th>Sinds</th><th></th></tr></thead>
      <tbody>
        <% users.forEach(function(u){ %>
          <tr>
            <td><%= u.username %><% if (u.id === user.id) { %> <span class="muted">(jij)</span><% } %></td>
            <td><%= u.role === 'admin' ? 'beheerder' : 'lid' %></td>
            <td class="muted"><%= u.created_at %></td>
            <td>
              <% if (u.id !== user.id) { %>
                <form method="post" action="/beheer/leden/<%= u.id %>/rol" class="inline">
                  <input type="hidden" name="_csrf" value="<%= csrf %>">
                  <button class="linkbtn" type="submit"><%= u.role === 'admin' ? 'Maak lid' : 'Maak beheerder' %></button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
</main>
<%- include('partials/foot') %>
