<%- include('partials/head', { title: 'Techniek & diensten — Beheer' }) %>
<%- include('partials/topbar') %>

<main class="beheer">
  <p class="beheer-foot"><a href="/beheer">&larr; Terug naar beheer</a></p>
  <header class="beheer-head">
    <h1>Techniek &amp; diensten</h1>
    <p>Waar deze site op draait: de gebruikte software, database, diensten en versies. Sleutels en wachtwoorden staan hier bewust niet bij.</p>
  </header>

  <% groups.forEach(function(g){ %>
    <section class="card">
      <h2><%= g.title %></h2>
      <table class="leden-table">
        <tbody>
          <% g.items.forEach(function(it){ %>
            <tr><th style="text-align:left;white-space:nowrap;padding-right:18px;"><%= it.name %></th><td><%= it.detail %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  <% }) %>
</main>
<%- include('partials/foot') %>
