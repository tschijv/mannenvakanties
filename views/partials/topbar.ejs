<header class="topbar">
  <a class="topbar-brand" href="/">Mannenvakanties</a>
  <nav class="topbar-nav">
    <a href="/">Album</a>
    <% if (user) { %>
      <a href="/beheer">Beheer</a>
      <form method="post" action="/uitloggen" class="inline">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button class="linkbtn">Uitloggen (<%= user.username %>)</button>
      </form>
    <% } else { %>
      <a href="/inloggen">Inloggen</a>
      <a class="cta" href="/aanmelden">Lid worden</a>
    <% } %>
  </nav>
</header>
<% if (flash) { %>
  <div class="flash flash-<%= flash.type %>"><%= flash.msg %></div>
<% } %>
