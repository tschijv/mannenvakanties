<%- include('partials/head', { title: year.year + ' — Mannenvakanties' }) %>
<%- include('partials/pubnav') %>

<header class="year-hero paper-grain">
  <div class="year-hero-inner">
    <p class="year-hero-eyebrow"><a href="/">&larr; Tijdlijn</a> &middot; <a href="/kaart">Kaart</a></p>
    <h1 class="year-hero-num"><%= year.year %></h1>
    <% if (year.place) { %><p class="year-hero-place"><%= year.place %></p><% } %>
    <% if (year.note) { %><p class="year-hero-note"><%= year.note %></p><% } %>
    <p class="year-hero-count"><%= year.photos.length %> foto<%= year.photos.length === 1 ? '' : "'s" %></p>
    <% if (user) { %><p class="year-tools"><a class="btn ghost" href="/download/jaar/<%= year.id %>">Download dit jaar (zip)</a></p><% } %>
  </div>
  <div class="postmark" aria-hidden="true"><small>MANNEN&middot;VAK</small><b><%= year.year %></b><small>&#9733;</small></div>
</header>

<main id="album">
  <section class="year paper-grain">
    <div class="grid">
      <% if (year.photos.length) { %>
        <% year.photos.forEach(function(p){ var rot = p.rotation || 0; var cs = (rot % 180 === 0) ? 1 : ((rot % 90 === 0) ? 1.34 : 1.66); %>
          <button class="mount has-photo" type="button"
                  data-src="<%= p.src %>" data-cap="<%= p.caption %>" data-id="<%= p.id %>" data-rot="<%= rot %>" data-oriented="<%= p.oriented ? 1 : 0 %>"
                  aria-label="Vergroot foto<%= p.caption ? ': ' + p.caption : '' %>">
            <div class="frame">
              <span class="corner tl"></span><span class="corner tr"></span>
              <span class="corner bl"></span><span class="corner br"></span>
              <img loading="lazy" decoding="async" src="<%= p.src %>" alt="<%= p.caption || 'Foto' %>" class="<%= p.oriented ? 'exif-fixed' : '' %>" style="transform:rotate(<%= rot %>deg) scale(<%= cs %>);">
            </div>
            <div class="caption"><%= p.caption || '· · ·' %></div>
          </button>
        <% }) %>
      <% } else { %>
        <p class="empty-note">Nog geen foto's in dit jaar.</p>
      <% } %>
    </div>
  </section>

  <% if (year.videos && year.videos.length) { %>
    <section class="year videos paper-grain">
      <h2 class="videos-head">Video's</h2>
      <div class="video-grid">
        <% year.videos.forEach(function(v){ %>
          <figure class="video-tile">
            <div class="video-embed">
              <iframe src="https://www.youtube-nocookie.com/embed/<%= v.youtube_id %>" title="<%= v.title || ('Video ' + year.year) %>" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
            </div>
            <% if (v.title) { %><figcaption class="video-cap"><%= v.title %></figcaption><% } %>
          </figure>
        <% }) %>
      </div>
    </section>
  <% } %>

  <p class="year-back"><a href="/">&larr; Terug naar de tijdlijn</a> &middot; <a href="/kaart">naar de kaart</a></p>
</main>

<footer class="colophon">
  <p class="mark">M&middot;V</p>
  <p>Mannenvakanties — het album</p>
</footer>

<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Foto vergroot">
  <button class="close" id="lbClose" aria-label="Sluiten">✕</button>
  <button class="lb-nav lb-prev" id="lbPrev" aria-label="Vorige foto">&#8249;</button>
  <button class="lb-nav lb-next" id="lbNext" aria-label="Volgende foto">&#8250;</button>
  <div class="lb-zoom">
    <button class="lb-zoom-btn" id="lbZoomOut" type="button" aria-label="Uitzoomen">&minus;</button>
    <button class="lb-zoom-btn" id="lbZoomIn" type="button" aria-label="Inzoomen">+</button>
  </div>
  <figure>
    <img id="lbImg" src="" alt="">
    <figcaption id="lbCap"></figcaption>
  </figure>
  <% if (user) { %><a class="lb-download" id="lbDownload" href="#" download>Download foto</a><% } %>
</div>

<script src="/gallery.js?v=<%= typeof ASSET_VER !== 'undefined' ? ASSET_VER : '1' %>"></script>
<%- include('partials/foot') %>
