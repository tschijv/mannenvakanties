<%- include('partials/head', { title: 'Beheer — Mannenvakanties' }) %>
<%- include('partials/topbar') %>

<main class="beheer">
  <header class="beheer-head">
    <h1>Beheer</h1>
    <p>Hallo <strong><%= user.username %></strong><%= user.role === 'admin' ? ' (beheerder)' : '' %>. Kies een jaar om de foto's te beheren, of maak een nieuw jaar aan.</p>
    <% if (user.role === 'admin') { %>
      <p class="beheer-adminlinks">
        <a href="/beheer/prullenbak">Prullenbak<% if (trashCount) { %> (<%= trashCount %>)<% } %></a>
        &middot; <a href="/beheer/leden">Leden &amp; beheerders</a>
        &middot; <a href="/beheer/logboek">Logboek</a>
        &middot; <a href="/beheer/statistieken">Statistieken</a>
        &middot; <a href="/beheer/reacties">Reacties<% if (typeof reactionCount !== 'undefined' && reactionCount) { %> (<%= reactionCount %>)<% } %></a>
      </p>
    <% } %>
    <p class="beheer-adminlinks">
      <a href="/namen">De mannen &amp; gezichten</a>
      <% if (typeof untaggedFaces !== 'undefined' && untaggedFaces) { %>&middot; <a href="/beheer/gezichten"><%= untaggedFaces %> gezicht<%= untaggedFaces === 1 ? '' : 'en' %> te benoemen</a><% } %>
    </p>
  </header>

  <section class="card">
    <h2>Nieuw jaar toevoegen</h2>
    <form method="post" action="/beheer/jaar" class="form row">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <label class="field grow"><span>Jaar of titel</span><input type="text" name="year" placeholder="bv. 2014" required></label>
      <label class="field grow"><span>Plaats <em>(optioneel)</em></span><input type="text" name="place" placeholder="bv. Maastricht"></label>
      <label class="field wide"><span>Korte notitie <em>(optioneel)</em></span><input type="text" name="note" placeholder="Een zin over dit jaar"></label>
      <label class="field"><span>Lat <em>(optioneel)</em></span><input type="text" name="lat" placeholder="bv. 50.41"></label>
      <label class="field"><span>Lng <em>(optioneel)</em></span><input type="text" name="lng" placeholder="bv. 6.11"></label>
      <div class="geocode-row">
        <button type="button" class="btn ghost" data-geocode>Zoek coördinaten bij plaats</button>
        <span class="muted" data-geocode-status></span>
      </div>
      <button class="btn" type="submit">Jaar aanmaken</button>
    </form>
  </section>

  <section class="card">
    <h2>Jaren</h2>
    <% if (years.length) { %>
      <ul class="year-list">
        <% years.forEach(function(y){ %>
          <li class="year-row">
            <a class="year-row-main" href="/beheer/jaar/<%= y.id %>">
              <span class="year-row-title"><%= y.year %><% if (y.place) { %> <span class="muted">&middot; <%= y.place %></span><% } %></span>
              <span class="year-row-meta">
                <% if (y.lat != null && y.lng != null) { %>
                  <span class="geo-badge has-geo" title="Coördinaten ingesteld">📍 op kaart</span>
                <% } else { %>
                  <span class="geo-badge no-geo" title="Nog geen coördinaten">⚠ geen coördinaten</span>
                <% } %>
                <span class="year-row-count"><%= y.photo_count %> foto<%= y.photo_count === 1 ? '' : "'s" %></span>
              </span>
            </a>
            <a class="btn small" href="/beheer/jaar/<%= y.id %>">Foto's beheren &rarr;</a>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p class="muted">Nog geen jaren. Maak er hierboven een aan.</p>
    <% } %>
  </section>

  <p class="beheer-foot"><a href="/">&larr; Terug naar het album</a></p>
</main>
<script src="/beheer.js?v=<%= typeof ASSET_VER !== 'undefined' ? ASSET_VER : '1' %>"></script>
<%- include('partials/foot') %>
