<%- include('partials/head', { title: year.year + ' — Beheer' }) %>
<%- include('partials/topbar') %>

<main class="beheer">
  <p class="beheer-foot"><a href="/beheer">&larr; Alle jaren</a></p>
  <% var mine = (user.role === 'admin' || user.id === year.created_by); %>

  <section class="card year-card">
    <div class="year-card-head">
      <h1><%= year.year %><% if (year.place) { %> <span class="muted">&middot; <%= year.place %></span><% } %></h1>
      <span class="count"><%= year.photos.length %> foto<%= year.photos.length === 1 ? '' : "'s" %></span>
    </div>
    <% if (year.note) { %><p class="year-card-note"><%= year.note %></p><% } %>

    <!-- Foto's uploaden -->
    <form method="post" action="/beheer/jaar/<%= year.id %>/fotos" enctype="multipart/form-data" class="form upload-form">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <label class="field grow"><span>Losse foto's kiezen <em>(meerdere mag; jpg, png, gif, webp &mdash; max 15 MB per stuk)</em></span>
        <input type="file" name="fotos" accept="image/*" multiple>
      </label>
      <label class="field grow"><span>&hellip;of een hele map kiezen <em>(alle foto's erin worden geüpload, max 200 per keer)</em></span>
        <input type="file" name="fotos" accept="image/*" multiple webkitdirectory>
      </label>
      <button class="btn" type="submit">Uploaden</button>
    </form>

    <!-- Foto's met bijschrift -->
    <% if (year.photos.length) { %>
      <form method="post" action="/beheer/jaar/<%= year.id %>/bulk" id="bulkbar" class="bulkbar" hidden>
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <input type="hidden" name="ids" id="bulkIds">
        <input type="hidden" name="action" id="bulkAction">
        <span class="bulk-count"><span id="bulkN">0</span> geselecteerd</span>
        <button type="button" class="btn ghost" data-bulk="links" title="90° linksom">&#8634; Links</button>
        <button type="button" class="btn ghost" data-bulk="rechts" title="90° rechtsom">&#8635; Rechts</button>
        <button type="button" class="btn ghost danger" data-bulk="verwijderen" data-confirm="%n foto('s) verwijderen? Ze blijven herstelbaar in de prullenbak.">Verwijderen</button>
        <button type="button" class="linkbtn" id="bulkClear">Wis selectie</button>
      </form>
      <p class="thumbs-hint muted">Sleep foto's om de volgorde te wijzigen. Vink foto's aan (hoekje linksboven) voor een bulkactie.</p>
      <div class="thumbs" data-order-url="/beheer/jaar/<%= year.id %>/volgorde" data-csrf="<%= csrf %>">
        <% year.photos.forEach(function(p){ var pmine = (user.role === 'admin' || user.id === p.uploaded_by); var isGroup = (year.group_photo_id === p.id); %>
          <div id="foto-<%= p.id %>" class="thumb<%= isGroup ? ' is-group' : '' %>">
            <% var rot = p.rotation || 0; %>
            <% if (pmine) { %><label class="thumb-check"><input type="checkbox" class="selbox" value="<%= p.id %>" aria-label="Selecteer foto"></label><% } %>
            <div class="thumb-pic">
              <img loading="lazy" src="<%= p.src %>" alt="<%= p.caption || 'Foto' %>" class="<%= p.oriented ? 'exif-fixed' : '' %>" style="transform:rotate(<%= rot %>deg);">
            </div>
            <% if (pmine) { %>
              <div class="rot-row">
                <form method="post" action="/beheer/foto/<%= p.id %>/draai" class="inline">
                  <input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="richting" value="links">
                  <button class="linkbtn rotbtn" type="submit" title="90° linksom draaien">&#8634; Links</button>
                </form>
                <form method="post" action="/beheer/foto/<%= p.id %>/draai" class="inline">
                  <input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="richting" value="rechts">
                  <button class="linkbtn rotbtn" type="submit" title="90° rechtsom draaien">&#8635; Rechts</button>
                </form>
                <% if (rot !== (p.base_rotation || 0)) { %>
                  <form method="post" action="/beheer/foto/<%= p.id %>/draai" class="inline">
                    <input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="richting" value="recht">
                    <button class="linkbtn rotbtn undo" type="submit" title="Terug naar de oorspronkelijke stand">&#8617; Rechtzetten</button>
                  </form>
                <% } %>
              </div>
            <% } %>
            <form method="post" action="/beheer/foto/<%= p.id %>/groepsfoto" class="grp-form">
              <input type="hidden" name="_csrf" value="<%= csrf %>">
              <button class="linkbtn grp<%= isGroup ? ' on' : '' %>" type="submit" title="<%= isGroup ? 'Klik om de groepsfoto-markering weg te halen' : 'Wijs deze foto aan als groepsfoto van dit jaar' %>"><%= isGroup ? '★ Groepsfoto' : 'Als groepsfoto' %></button>
            </form>
            <% if (pmine) { %>
              <form method="post" action="/beheer/foto/<%= p.id %>" class="cap-form">
                <input type="hidden" name="_csrf" value="<%= csrf %>">
                <input type="text" name="caption" value="<%= p.caption %>" placeholder="Bijschrift…" maxlength="120">
                <button class="linkbtn save" type="submit">Opslaan</button>
              </form>
              <div class="names-block">
                <% if (p.names.length) { %>
                  <ul class="name-chips">
                    <% p.names.forEach(function(nm){ %>
                      <li class="name-chip">
                        <a href="/persoon/<%= nm.person_id %>"><%= nm.name || 'naamloos' %></a>
                        <form method="post" action="/beheer/gezicht/<%= nm.face_id %>/verwijderen" class="inline" onsubmit="return confirm('Naam van deze foto halen?');">
                          <input type="hidden" name="_csrf" value="<%= csrf %>">
                          <input type="hidden" name="back" value="/beheer/jaar/<%= year.id %>#foto-<%= p.id %>">
                          <button class="chip-x" type="submit" title="Naam van deze foto halen" aria-label="Verwijderen">✕</button>
                        </form>
                      </li>
                    <% }) %>
                  </ul>
                <% } %>
                <form method="post" action="/beheer/foto/<%= p.id %>/gezicht" class="name-add">
                  <input type="hidden" name="_csrf" value="<%= csrf %>">
                  <input type="hidden" name="x" value="0"><input type="hidden" name="y" value="0">
                  <input type="hidden" name="w" value="1"><input type="hidden" name="h" value="1">
                  <input type="hidden" name="back" value="/beheer/jaar/<%= year.id %>#foto-<%= p.id %>">
                  <input type="text" name="new_name" list="namenlijst" placeholder="+ naam wie erop staat" maxlength="80" required>
                  <button class="linkbtn save" type="submit">Naam toevoegen</button>
                </form>
                <a class="name-tag-link" href="/beheer/foto/<%= p.id %>/gezichten">vak tekenen…</a>
              </div>
              <form method="post" action="/beheer/foto/<%= p.id %>/verwijderen" class="del-form" onsubmit="return confirm('Deze foto verwijderen? Een beheerder kan hem nog herstellen.');">
                <input type="hidden" name="_csrf" value="<%= csrf %>">
                <button class="linkbtn danger" type="submit">Verwijderen</button>
              </form>
            <% } else { %>
              <p class="cap-readonly"><%= p.caption || '· · ·' %></p>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="muted">Nog geen foto's in dit jaar.</p>
    <% } %>

    <% if (user.role === 'admin' && year.photos.length > 1) { %>
      <form method="post" action="/beheer/jaar/<%= year.id %>/ontdubbel" class="ontdubbel-form" onsubmit="return confirm('Dubbele foto\'s opsporen en naar de prullenbak verplaatsen? Van elke dubbele blijft er één staan; je kunt ze altijd herstellen.');">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button class="btn ghost" type="submit">Dubbele foto's opruimen</button>
        <span class="muted">Vergelijkt de inhoud van de foto's; identieke exemplaren gaan naar de prullenbak.</span>
      </form>
    <% } %>

    <!-- Video's (YouTube) -->
    <div class="beheer-videos">
      <h3>Video's (YouTube)</h3>
      <form method="post" action="/beheer/jaar/<%= year.id %>/video" class="form row">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <label class="field grow"><span>YouTube-link</span><input type="url" name="url" placeholder="https://www.youtube.com/watch?v=… of https://youtu.be/…" required></label>
        <label class="field grow"><span>Titel <em>(optioneel)</em></span><input type="text" name="title" placeholder="bv. Aankomst in Waimes"></label>
        <button class="btn" type="submit">Video toevoegen</button>
      </form>
      <% if (year.videos && year.videos.length) { %>
        <ul class="video-list">
          <% year.videos.forEach(function(v){ %>
            <li class="video-row">
              <img class="video-thumb" src="https://i.ytimg.com/vi/<%= v.youtube_id %>/mqdefault.jpg" alt="" loading="lazy">
              <span class="video-row-title"><%= v.title || ('youtu.be/' + v.youtube_id) %></span>
              <form method="post" action="/beheer/video/<%= v.id %>/verwijderen" class="inline" onsubmit="return confirm('Deze video verwijderen?');">
                <input type="hidden" name="_csrf" value="<%= csrf %>">
                <button class="linkbtn danger" type="submit">Verwijderen</button>
              </form>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="muted">Nog geen video's bij dit jaar.</p>
      <% } %>
    </div>

    <!-- Jaar bewerken / verwijderen -->
    <% if (mine) { %>
      <details class="year-edit">
        <summary>Jaar bewerken<% if (user.role === 'admin') { %> of verwijderen<% } %></summary>
        <form method="post" action="/beheer/jaar/<%= year.id %>" class="form row">
          <input type="hidden" name="_csrf" value="<%= csrf %>">
          <label class="field grow"><span>Jaar/titel</span><input type="text" name="year" value="<%= year.year %>" required></label>
          <label class="field grow"><span>Plaats</span><input type="text" name="place" value="<%= year.place %>"></label>
          <label class="field wide"><span>Notitie</span><input type="text" name="note" value="<%= year.note %>"></label>
          <label class="field"><span>Breedtegraad <em>(lat)</em></span><input type="text" name="lat" value="<%= year.lat != null ? year.lat : '' %>" placeholder="bv. 50.41"></label>
          <label class="field"><span>Lengtegraad <em>(lng)</em></span><input type="text" name="lng" value="<%= year.lng != null ? year.lng : '' %>" placeholder="bv. 6.11"></label>
          <div class="geocode-row">
            <button type="button" class="btn ghost" data-geocode>Zoek coördinaten bij plaats</button>
            <span class="muted" data-geocode-status></span>
          </div>
          <button class="btn" type="submit">Opslaan</button>
        </form>
        <p class="muted coord-hint">Vul hierboven de plaats in en klik op "Zoek coördinaten bij plaats" — dan worden de twee getallen vanzelf ingevuld. Klik daarna op Opslaan. (Je kunt ze ook met de hand invullen, of leeg laten om dit jaar van de kaart te houden.)</p>
        <% if (user.role === 'admin') { %>
          <form method="post" action="/beheer/jaar/<%= year.id %>/verwijderen" onsubmit="return confirm('Het hele jaar \'<%= year.year %>\' en alle foto\'s erin definitief verwijderen?');" class="del-year">
            <input type="hidden" name="_csrf" value="<%= csrf %>">
            <button class="linkbtn danger" type="submit">Dit jaar verwijderen</button>
          </form>
        <% } %>
      </details>
    <% } %>
  </section>

  <datalist id="namenlijst">
    <% names.forEach(function(n){ %><option value="<%= n %>"></option><% }) %>
  </datalist>
</main>
<script src="/beheer.js?v=<%= typeof ASSET_VER !== 'undefined' ? ASSET_VER : '1' %>"></script>
<%- include('partials/foot') %>
